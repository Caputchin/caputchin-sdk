{
  "name": "@caputchin/widget",
  "version": "0.0.0",
  "description": "Customer-facing CAPTCHA web component for the Caputchin platform",
  "keywords": ["captcha", "widget", "web-component", "verification", "caputchin"],
  "homepage": "https://github.com/Caputchin/caputchin-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caputchin/caputchin-sdk"
  },
  "bugs": {
    "url": "https://github.com/Caputchin/caputchin-sdk/issues"
  },
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/widget.d.ts",
      "import": "./dist/widget.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/widget.mjs",
    "./dist/widget.js"
  ],
  "scripts": {
    "prebuild": "node scripts/build-iframe-runtime.mjs",
    "build": "tsup",
    "build:prod": "node scripts/build-iframe-runtime.mjs && CAPUTCHIN_API_HOST=https://api.caputchin.com tsup --minify",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cap.js/widget": "~0.1.50"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.21.0",
    "happy-dom": "^14.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
