{
  "name": "@caputchin/widget",
  "version": "4.0.0",
  "description": "Customer-facing CAPTCHA + game widgets for the Caputchin platform",
  "keywords": [
    "captcha",
    "widget",
    "web-component",
    "verification",
    "caputchin"
  ],
  "homepage": "https://github.com/Caputchin/caputchin-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caputchin/caputchin-sdk"
  },
  "bugs": {
    "url": "https://github.com/Caputchin/caputchin-sdk/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/widget.d.ts",
      "import": "./dist/widget.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/widget.mjs",
    "./dist/widget.js",
    "./src/cap/wasm-host-esm.ts",
    "./src/cap/wasm-host-iife.ts"
  ],
  "scripts": {
    "prebuild": "node scripts/build-iframe-runtime.mjs",
    "build": "tsup",
    "build:prod": "node scripts/build-iframe-runtime.mjs && CAPUTCHIN_API_HOST=https://caputchin.com tsup --minify",
    "dev": "node scripts/dev.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc && node ../../scripts/normalize-docs.mjs docs"
  },
  "dependencies": {
    "@cap.js/widget": "~0.1.53"
  },
  "devDependencies": {
    "@cap.js/wasm": "0.0.7",
    "@caputchin/game-sdk": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.21.0",
    "happy-dom": "^14.0.0",
    "pako": "2.1.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
