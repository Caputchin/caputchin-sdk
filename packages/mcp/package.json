{
  "name": "@caputchin/mcp",
  "version": "1.0.0",
  "description": "MCP server for managing Caputchin resources via AI agents",
  "keywords": [
    "caputchin",
    "mcp",
    "model-context-protocol",
    "ai",
    "management"
  ],
  "homepage": "https://github.com/Caputchin/caputchin-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caputchin/caputchin-sdk"
  },
  "bugs": {
    "url": "https://github.com/Caputchin/caputchin-sdk/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "caputchin-mcp": "./dist/cli.js"
  },
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
