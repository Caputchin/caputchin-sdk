{
  "name": "@caputchin/replay-wasm",
  "version": "0.2.0",
  "description": "Generic host glue for a Caputchin headless WASM replay artifact: precompiled-module instantiation, linear-memory marshalling over the cap_alloc/cap_run C-ABI, and gzip+base64 inline decode.",
  "keywords": [
    "caputchin",
    "replay",
    "wasm",
    "deterministic",
    "captcha"
  ],
  "homepage": "https://github.com/Caputchin/caputchin-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Caputchin/caputchin-sdk"
  },
  "bugs": {
    "url": "https://github.com/Caputchin/caputchin-sdk/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@caputchin/replay-contract": "workspace:*",
    "fflate": "^0.8.2"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docs": "typedoc && node ../../scripts/normalize-docs.mjs docs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
