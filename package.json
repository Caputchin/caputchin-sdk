{
  "name": "caputchin-sdk",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "verify": "pnpm -r typecheck && pnpm -r --if-present test",
    "verify:fast": "pnpm --filter @caputchin/mcp --filter @caputchin/game-sdk typecheck && pnpm --filter @caputchin/mcp --filter @caputchin/game-sdk --if-present test",
    "coverage": "pnpm -r --if-present coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
